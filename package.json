{
  "name": "tlef-biocbot",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node src/server.js",
    "dev": "npm-run-all --parallel dev:*",
    "dev:server": "cross-env NODE_ENV=development nodemon src/server.js",
    "dev:client": "browser-sync start --proxy 'http://localhost:8085' --files 'public'",
    "diagnose": "node diagnose.js",
    "grant:system-admin": "node scripts/grant-system-admin.js",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test --config=playwright.a11y.config.js",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch",
    "test:unit:coverage": "jest --coverage",
    "test:unit:monocart": "jest --config jest.monocart.config.js",
    "test:monocart": "playwright test",
    "test:monocart:chat-rag": "playwright test tests/e2e/chat-rag-documents.spec.js",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:report:monocart": "monocart show-report monocart-report/index.html",
    "test:report:coverage": "monocart show-report coverage-reports/e2e/index.html",
    "test:report:unit": "monocart show-report coverage-reports/unit-monocart/index.html"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@qdrant/js-client-rest": "^1.15.1",
    "bad-words": "^3.0.4",
    "bcryptjs": "^2.4.3",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^17.0.1",
    "express": "^5.1.0",
    "express-session": "^1.18.0",
    "js-tiktoken": "^1.0.21",
    "mongodb": "^6.17.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "passport-saml": "^3.2.4",
    "passport-ubcshib": "0.1.4",
    "ubc-genai-toolkit-chunking": "^0.1.0",
    "ubc-genai-toolkit-core": "^0.1.0",
    "ubc-genai-toolkit-document-parsing": "^0.1.0",
    "ubc-genai-toolkit-embeddings": "^0.1.1",
    "ubc-genai-toolkit-llm": "^0.2.3"
  },
  "optionalDependencies": {
    "@ubc/ubc-genai-toolkit-course-list-sync": "^0.1.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.59.1",
    "browser-sync": "^3.0.4",
    "cross-env": "^7.0.3",
    "delegates": "^1.0.0",
    "jest": "^30.4.2",
    "jest-monocart-coverage": "^1.1.1",
    "monocart-reporter": "^2.11.2",
    "nodemon": "^3.1.10",
    "npm-run-all": "^4.1.5",
    "supertest": "^7.2.2"
  }
}
